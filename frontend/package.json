{
    "name": "frontend",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "dev:wails": "vite dev --host --port 5173",
        "build": "vite build",
        "build:wails": "vite build",
        "preview": "vite preview",
        "prepare": "svelte-kit sync || echo ''",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "generate:api": "npx openapi-typescript ../api/openapi.yaml -o src/lib/api.generated.ts"
    },
    "devDependencies": {
        "@sveltejs/adapter-auto": "^7.0.0",
        "@sveltejs/adapter-static": "^3.0.10",
        "@sveltejs/kit": "^2.50.2",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "svelte": "^5.51.0",
        "svelte-check": "^4.3.6",
        "typescript": "^5.9.3",
        "vite": "^7.3.1"
    }
}
